// protocol/shell_state.fbs

namespace NiriShell;

table Workspace {
  id: uint64;
  name: string;
  is_active: bool;
}

table ShellState {
  workspaces: [Workspace];
  battery_percent: int8;
  active_window_title: string;
  audio_volume: int8;
  audio_muted: bool;
  network_name: string;
}

root_type ShellState;
